# DeepSeek API Key（必填，用于情绪分析、诗句、诗意命名、散文）
# 在 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY = "your-deepseek-api-key-here"

# Unsplash Access Key（选填，用于动态壁纸背景）
# 在 https://unsplash.com/developers 注册应用获取
UNSPLASH_ACCESS_KEY = "your-unsplash-access-key-here"

# GIPHY API Key（选填，用于微动效氛围 GIF）
# 在 https://developers.giphy.com 创建应用获取
GIPHY_API_KEY = "your-giphy-api-key-here"

# 网站 URL（选填，用于分享卡片二维码）
SITE_URL = "https://your-app-name.streamlit.app"
